# Copy to a real environment configuration (e.g. Lambda env vars) - do NOT commit a filled-in version.
# These are the environment variables the Lambda functions read.

# Shared
VISITORS_TABLE=visitors
PASSCODES_TABLE=passcodes
SNS_TOPIC_ARN=arn:aws:sns:<REGION>:<ACCOUNT_ID>:smartdoor-otp

# LF1 - Visitor Identification
BUCKET=my-smartdoor-bucket
SEND_OTP_LAMBDA=smartdoor-send-otp
WEBSITE_BASE=http://my-smartdoor-bucket.s3-website-us-east-1.amazonaws.com

# LF2 - OTP Generator
OTP_TTL_SECONDS=300
